{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm build",
  "outputDirectory": "dist/public",
  "functions": {
    "api/index.ts": {
      "includeFiles": "server/moodboards/**"
    }
  },
  "routes": [
    {
      "src": "^/api/(.*)$",
      "dest": "/api/index"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^(?!/api/).*$",
      "dest": "/index.html"
    }
  ]
}
